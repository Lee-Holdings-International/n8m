{
  "name": "@digibear/n8m",
  "version": "0.0.1",
  "description": "Agentic n8n CLI wrapper - A Skill Bridge for n8n workflow automation",
  "author": "n8m",
  "bin": {
    "n8m": "./bin/run.js"
  },
  "homepage": "https://github.com/lcanady/n8m",
  "main": "dist/index.js",
  "type": "module",
  "exports": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@supabase/supabase-js": "^2.93.3",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "ink": "^6.6.0",
    "ink-gradient": "^3.0.0",
    "ink-link": "^5.0.0",
    "ink-markdown": "^1.0.4",
    "ink-spinner": "^5.0.0",
    "keytar": "^7.9.0",
    "open": "^11.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^5",
    "@types/cli-progress": "^3.11.6",
    "@types/keytar": "^4.4.0",
    "@types/mocha": "^10",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.10",
    "chai": "^5",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-oclif-typescript": "^3",
    "mocha": "^10",
    "oclif": "^4",
    "pm2": "^6.0.14",
    "shx": "^0.3.4",
    "ts-node": "^10",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "n8m",
    "dirname": "n8m",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "create": {
        "description": "Generate or modify n8n workflows"
      },
      "deploy": {
        "description": "Push workflows to n8n instance"
      },
      "test": {
        "description": "Run end-to-end workflow tests"
      }
    }
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint .",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "n8m": "./bin/run.js",
    "start:server": "tsx src/server/index.ts",
    "watch:server": "tsx watch src/server/index.ts",
    "watch:cli": "tsc -b -w",
    "dev": "concurrently \"npm:watch:server\" \"npm:watch:cli\" -c \"magenta,blue\" -n \"SERVER,CLI\"",
    "server:start": "pm2 start src/server/index.ts --name n8m-server --interpreter ./node_modules/.bin/tsx --watch --ignore-watch='node_modules .git'",
    "server:stop": "pm2 delete n8m-server",
    "server:restart": "pm2 restart n8m-server",
    "server:logs": "pm2 logs n8m-server",
    "server:status": "pm2 status",
    "version": "oclif readme && git add README.md"
  }
}
