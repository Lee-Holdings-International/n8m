{
  "name": "@lhi/n8m",
  "version": "1.0.1",
  "description": "Agentic n8n CLI wrapper - A Skill Bridge for n8n workflow automation",
  "author": "Lem Canady",
  "keywords": [
    "n8n",
    "workflow",
    "automation",
    "ai",
    "agentic",
    "cli",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "langgraph",
    "mcp",
    "model-context-protocol",
    "workflow-automation",
    "workflow-generator",
    "no-code",
    "low-code",
    "devtools"
  ],
  "license": "MIT",
  "bin": {
    "n8m": "./bin/run.js"
  },
  "homepage": "https://github.com/Lee-Holdings-International/n8m",
  "main": "dist/index.js",
  "type": "module",
  "exports": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "docs",
    "banner.txt",
    "n8m-cover.png",
    "n8m-logo-v2.png",
    "n8m-logo-light.png",
    "n8m-logo-mono.png",
    "oclif.manifest.json"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^4.0.0",
    "@inquirer/confirm": "^5.0.0",
    "@inquirer/input": "^4.0.0",
    "@inquirer/select": "^4.0.0",
    "@langchain/core": "^1.1.18",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@types/inquirer": "^9.0.9",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.2.3",
    "ink": "^6.6.0",
    "ink-gradient": "^3.0.0",
    "ink-link": "^5.0.0",
    "ink-markdown": "^1.0.4",
    "ink-multiline-input": "^0.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^13.2.2",
    "jsonrepair": "^3.13.2",
    "openai": "^4.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^5",
    "@types/cli-progress": "^3.11.6",
    "@types/mocha": "^10",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.10",
    "chai": "^5",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-oclif-typescript": "^3",
    "mocha": "^10",
    "oclif": "^4",
    "puppeteer": "^24.38.0",
    "shx": "^0.3.4",
    "ts-node": "^10",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "n8m",
    "dirname": "n8m",
    "commands": "./dist/commands",
    "helpClass": "./dist/help.js",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "create": {
        "description": "Generate or modify n8n workflows"
      },
      "deploy": {
        "description": "Push workflows to n8n instance"
      },
      "test": {
        "description": "Run end-to-end workflow tests"
      }
    }
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b && shx mkdir -p dist/resources && shx cp src/resources/*.json dist/resources/ && shx cp src/fixture-schema.json dist/fixture-schema.json",
    "lint": "eslint .",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "NODE_ENV=test mocha --forbid-only \"test/**/*.test.ts\"",
    "n8m": "./bin/run.js",
    "start": "npm run build && ./bin/run.js",
    "dev": "tsc -b -w",
    "generate-patterns": "tsx scripts/generate-patterns.ts",
    "version": "oclif readme && git add README.md"
  }
}
