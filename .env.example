# ==============================================
# n8m Configuration
# ==============================================

# ==============================================
# AI Provider
# ==============================================
# Set AI_PROVIDER to one of: openai, anthropic, gemini
# Or leave it unset and configure AI_BASE_URL manually for any OpenAI-compatible API.

# Your API key for the chosen provider
AI_API_KEY=your_api_key_here

# Provider preset (sets the base URL and default model automatically)
# Options: openai | anthropic | gemini
AI_PROVIDER=openai

# Optional: override the model (defaults per provider: gpt-4o / claude-sonnet-4-6 / gemini-2.5-flash)
# AI_MODEL=gpt-4o

# Optional: custom base URL for any OpenAI-compatible API (Ollama, Groq, Together, LM Studio, etc.)
# AI_BASE_URL=http://localhost:11434/v1

# Legacy: GEMINI_API_KEY is still supported as a fallback (sets provider to gemini automatically)
# GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================
# n8n Instance
# ==============================================
# These are optional — you can also set them via `n8m config`
# N8N_API_URL=http://localhost:5678/api/v1
# N8N_API_KEY=your_n8n_api_key_here
