# ==============================================
# n8m Service Configuration
# ==============================================

# Server Port (Default: 3000)
PORT=3000

# ==============================================
# AI Provider (Gemini)
# ==============================================
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================
# n8n Integration (Local CLI Only)
# ==============================================
# NOTE: The SaaS Server does NOT need these credentials.
# They are only used if you are running the CLI locally in dev mode
# without using 'n8m config'.
# N8N_API_URL=http://localhost:5678/api/v1
# N8N_API_KEY=your_n8n_api_key_here

# ==============================================
# SaaS Infrastructure (Supabase)
# ==============================================
# URL and Anon Key from your Supabase Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
